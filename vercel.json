{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/3d-landing.html"
    },
    {
      "src": "/3d-landing.html",
      "dest": "/public/3d-landing.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
